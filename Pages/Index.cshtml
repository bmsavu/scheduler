@page
@model Scheduler.Pages.IndexModel
@{
    ViewData["Title"] = "Rezervare loc etaj 1 - BK RO Team";
}

@section Head {
    <meta http-equiv="Refresh" content="60" />
}

<form method="post">
    <div class="row info">
        <div class="col-lg-4 col-md-6 col-sm-4 col-xs-6">
            <img width="100px" class="img-responsive" src="https://see.asseco.com/files/private/assets/images/asseco_southeasterneurope_logo.svg" />
        </div>
        <div class="col-lg-3 col-lg-offset-5 col-md-4 col-md-offset-2 col-sm-6 col-sm-offset-2 col-xs-6 info-txt">
            <b>Tu ești:</b> <span>@Model.FullName <br />(@Model.UserName)</span>
        </div>
        <div>
            <a asp-page="/Add" class="btn btn-primary">Adaugă rezervare</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <table>
                <tr>
                    <td style="vertical-align:top;">
                        <div><img src="~/img/schema.png" /></div>
                        <div class="info-label">
                            <span class="label label-warning">!</span>ATENȚIE: Tabelul arată rezervarile în ordine cronologică si in ordinea locurilor ET1L01, ET1L02, ...), incepand cu data de azi @DateTime.Now.ToString("dd-MM-yyyy").<br />
                            <span class="label label-warning">!</span>Nu se poate rezerva acelasi loc de 2 ori in aceeasi zi (verificati inainte de adaugare).<br />
                            <span class="label label-warning">!</span>Nu se pot rezerva 2 locuri diferite, aceeasi persoana si in aceeasi zi (verificati inainte de adaugare).<br />
                            <span class="label label-warning">!</span>Rezervarie mai vechi de data curenta se sterg automat.<br />
                            <span class="label label-warning">!</span>Pagina se reîncarcă automat la fiecare minut.<br />
                        </div>
                    </td>
                    <td style="vertical-align:top;">
                        <div class="col-md-12">
                            <h1>Lista rezervarilor (incepand cu data de azi @DateTime.Now.ToString("dd-MM-yyyy")):</h1>
                            <table class="table table-striped table-hover table-bordered">
                                <thead>
                                    <tr>
                                        <th><a asp-page="/Add">#</a></th>
                                        <th>Data/Ora</th>
                                        <th>Nume</th>
                                        <th>Loc</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                @for (int i = 0; i < Model.Rezervari.Count; i++)
                                {
                                    var r = Model.Rezervari[i];
                                    var roculture = new System.Globalization.CultureInfo("ro-RO");
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@r.Ora.ToString("dd.MM.yyyy HH:mm")&nbsp;(@roculture.DateTimeFormat.GetDayName(r.Ora.DayOfWeek))</td>
                                        <td>@r.NumeComplet</td>
                                        <td>@r.Destinatie</td>
                                        <td class="btn-delete">
                                            @if (r.IsOwner)
                                            {
                                                <button type="submit" asp-page-handler="Delete" asp-route-id="@r.OrarId"
                                                        class="btn btn-danger"
                                                        onclick="return confirm('Ești sigur(ă) că vrei să ștergi această programare?');">X</button>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
            </table>
        </div>
        <a asp-page="/Add" class="btn btn-primary">Adaugă rezervare</a>
    </div>
</form>
