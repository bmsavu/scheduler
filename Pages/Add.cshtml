@page
@model Scheduler.Pages.AddModel
@{
    ViewData["Title"] = "Adauga o planificare";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="card">
            <div class="card-header bg-body-tertiary">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-1"></i> Planificare noua</h5>
            </div>
            <div class="card-body form-section">
                <form method="post">
                    <input type="hidden" asp-for="Rol" />

                    <!-- Date, Time, Repeat -->
                    <div class="row g-3 mb-4">
                        <div class="col-sm-4">
                            <label asp-for="Data" class="form-label">Data</label>
                            <input type="date" asp-for="Data" class="form-control" />
                        </div>
                        <div class="col-4 col-sm-2">
                            <label asp-for="Hour" class="form-label">Ora</label>
                            <input type="number" asp-for="Hour" class="form-control" min="0" max="23" />
                        </div>
                        <div class="col-4 col-sm-2">
                            <label asp-for="Minute" class="form-label">Minut</label>
                            <input type="number" asp-for="Minute" class="form-control" min="0" max="59" />
                        </div>
                        <div class="col-4 col-sm-4">
                            <label asp-for="Repeat" class="form-label">Repetari</label>
                            <div class="input-group">
                                <input type="number" asp-for="Repeat" class="form-control" min="1" max="5" />
                                <span class="input-group-text">zile</span>
                            </div>
                        </div>
                    </div>

                    <!-- Desk selector grid -->
                    <div class="mb-4">
                        <label class="form-label">Selecteaza locul</label>
                        <div class="desk-grid row row-cols-2 row-cols-sm-4 g-2">
                            @for (int i = 1; i <= 16; i++)
                            {
                                var code = $"ET1L{i:D2}";
                                var isChecked = Model.Destinatie == code;
                                <div class="col">
                                    <input type="radio" class="btn-check" name="Destinatie" id="desk-@i" value="@code"
                                           @(isChecked ? "checked" : "") autocomplete="off" />
                                    <label class="btn btn-outline-primary w-100 py-3" for="desk-@i">
                                        <i class="bi bi-pc-display d-block mb-1" style="font-size:1.2rem;"></i>
                                        <small>@code</small>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Warnings -->
                    <div class="alert alert-info small mb-4">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>De retinut:</strong>
                        <ul class="mb-0 mt-1 ps-3">
                            <li>Maxim 5 repetari (rezervari in zile consecutive).</li>
                            <li>Repetarile se adauga in zile calendaristice consecutive.</li>
                            <li>Data/ora nu poate fi in trecut (sistemul pune automat data/ora curenta + 5 min).</li>
                        </ul>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Adauga
                        </button>
                        <a asp-page="/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Inapoi
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
