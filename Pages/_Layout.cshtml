<!DOCTYPE html>
<html lang="ro" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    @RenderSection("Head", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-md bg-body-tertiary shadow-sm sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                <img src="https://see.asseco.com/files/private/assets/images/asseco_southeasterneurope_logo.svg"
                     alt="Asseco SEE" height="28" />
                <span class="fw-semibold d-none d-sm-inline">Scheduler</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">
                            <i class="bi bi-calendar-check"></i> Rezervari
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    @if (ViewData["FullName"] != null)
                    {
                        <span class="text-body-secondary small">
                            <i class="bi bi-person-circle"></i>
                            @ViewData["FullName"]
                        </span>
                    }
                    <button id="btnTheme" class="btn btn-sm btn-outline-secondary" type="button" title="Schimba tema">
                        <i class="bi bi-moon-stars"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main class="container-fluid py-4">
        @RenderBody()
    </main>

    <footer class="text-center text-body-tertiary small py-3">
        Scheduler &copy; @DateTime.Now.Year &mdash; BK RO Team
    </footer>

    <div id="toastContainer" class="toast-container position-fixed bottom-0 end-0 p-3"></div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js"></script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["SuccessMessage"]', 'success'));</script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["ErrorMessage"]', 'danger'));</script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
